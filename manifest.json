{
  "manifest_version": 3,
  "name": "CSS Copy Tool",
  "version": "1.0.0",
  "description": "Instantly copy CSS from any element. Lightweight alternative to CSS Scan.",
  "permissions": ["activeTab", "scripting", "clipboardWrite"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["content/content.css"],
      "js": ["content/content.js"],
      "run_at": "document_end"
    }
  ],
  "commands": {
    "toggle-inspector": {
      "suggested_key": {
        "default": "Alt+Shift+C",
        "mac": "Alt+Shift+C"
      },
      "description": "Toggle CSS Inspector"
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}
